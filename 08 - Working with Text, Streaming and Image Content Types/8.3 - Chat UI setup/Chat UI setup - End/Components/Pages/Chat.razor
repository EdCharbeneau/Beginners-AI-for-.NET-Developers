@page "/"
@page "/chat"
@using Microsoft.Extensions.AI

<PageTitle>Home</PageTitle>
<ChatMessageWrapper>
    @foreach (var m in history)
    {
        if (m.Role == ChatRole.Assistant)
        {
            @foreach (var content in m.Contents)
            {
                if (content is TextContent textContent)
                {
                    <AssistantMessage>
                        <MarkdownText Text="@m.Text" />
                    </AssistantMessage>
                }
            }
        }
    }
    <LoadingIndicator IsLoading="@isLoading" StreamingText="" />
</ChatMessageWrapper>
<ChatInput OnSendMessage="HandleSendMessage" 
    IsLoading="@isLoading" />

@code {

    private IChatClient ai;
    public Chat(IChatClient client)
    {
        ai = client;
    }
    List<ChatMessage> history = [];

    bool isLoading = false;
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        // Logic to handle the sent message
        // Initialize the chat client or any other necessary services
        ChatMessage systemMessage = new ChatMessage(
        ChatRole.System,
        "You are a helpful assistant."
        );
        history.Add(systemMessage);
        ChatResponse response = await ai.GetResponseAsync(systemMessage);
        history.AddMessages(response);
        isLoading = false;
    }

    private async Task HandleSendMessage(string message)
    {
        isLoading = true;
        // Logic to handle the sent message
        isLoading = false;
    }

    @* private void HandleSendImage(byte[] imageBytes, string mediaType)
